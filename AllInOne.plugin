[URL Rewrite]

[Script]
# 东东萌宠
cron "15 17 * * *" script-path=https://raw.gh.fakev.cn/KingRan/KR/main/jd_pet.js, tag=东东萌宠
cron "1 0 * * *" script-path=https://raw.githubusercontent.com/dompling/Script/master/jd/JD_extra_sign.js, tag=京东多账号（多合一签到）

http-request https:\/\/wq\.jd\.com\/user_new\/info\/GetJDUserInfoUnion tag=获取京东Cookie, script-path=https://raw.githubusercontent.com/dompling/Script/master/jd/JD_extra_cookie.js

[MITM]
hostname = wq.jd.com
